# Copy to `.env` in this folder. Restart Streamlit after editing.

# Required: https://console.groq.com/keys — create a key and paste it here (starts with gsk_)
GROQ_API_KEY=

# Optional: model id (default: llama-3.3-70b-versatile). Other options: llama-3.1-8b-instant, mixtral-8x7b-32768
# GROQ_MODEL=llama-3.3-70b-versatile
